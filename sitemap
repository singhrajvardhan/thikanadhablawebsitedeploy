        #menu a {
            color: var(--cream);
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            padding: 10px 18px;
            border-radius: 6px;
            transition: var(--transition);
            position: relative;
            letter-spacing: 0.5px;
        }

        #menu a::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 50%;
            width: 0;
            height: 2px;
            background-color: var(--gold);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        #menu a:hover::after {
            width: 70%;
        }

        #menu a.selected {
            color: var(--gold);
            background: rgba(255,255,255,0.1);
            border-bottom: 2px solid var(--gold);
        }

        #menu a:hover {
            color: var(--gold);
            transform: translateY(-2px);
