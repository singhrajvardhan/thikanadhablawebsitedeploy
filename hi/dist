    <script>
        // Mobile nav toggle
        const navToggle = document.getElementById('navToggle');
        const primaryNav = document.getElementById('primaryNav');
        navToggle.addEventListener('click', () => {
            const open = primaryNav.classList.toggle('open');
            navToggle.setAttribute('aria-expanded', open);
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && primaryNav.classList.contains('open')) {
                primaryNav.classList.remove('open');
                navToggle.setAttribute('aria-expanded', false);
            }
        });

        // Search function for contacts table
        function searchContacts() {
            let input = document.getElementById("search");
            let filter = input.value.toUpperCase();
            let table = document.getElementById("contactsTable");
            let tr = table.getElementsByTagName("tr");

            for (let i = 0; i < tr.length; i++) {
                let nameTd = tr[i].getElementsByTagName("td")[1];
                let mobileTd = tr[i].getElementsByTagName("td")[2];
                
                if (nameTd || mobileTd) {
                    let nameValue = nameTd ? (nameTd.textContent || nameTd.innerText) : "";
                    let mobileValue = mobileTd ? (mobileTd.textContent || mobileTd.innerText) : "";
                    
                    if (nameValue.toUpperCase().indexOf(filter) > -1 || 
                        mobileValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }       
            }
        }
    </script>

