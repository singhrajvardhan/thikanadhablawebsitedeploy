                        <tr><td>13</td><td>आराध्य देव</td><td>श्री सीताराम जी</td></tr>
                        <tr><td>14</td><td>कुलदेव</td><td>नीलकंठ महादेव जी</td></tr>
                        <tr><td>15</td><td>अभिवादन</td><td>जय रघुनाथ जी</td></tr>
