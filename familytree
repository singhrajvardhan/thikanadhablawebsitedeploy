        });

        // Blinking message animation
        const messages = [
            { text: "राघवाय नमः", color: "#ffd700" },
            { text: "जय माँ आसावरी", color: "#ff6b6b" },
            { text: "🌳 Badgujar Vanshavali 🌳", color: "#ffb347" }
        ];
        let msgIndex = 0;
        const msgEl = document.getElementById('blinking-message');
        
        function updateBlinkingMessage() {
            if(msgEl) {
                msgEl.style.opacity = '0';
                setTimeout(() => {
                    msgIndex = (msgIndex + 1) % messages.length;
                    msgEl.textContent = messages[msgIndex].text;
                    msgEl.style.color = messages[msgIndex].color;
                    msgEl.style.opacity = '1';
                }, 400);
            }
        }
        
        if(msgEl) {
            msgEl.textContent = messages[0].text;
            msgEl.style.color = messages[0].color;
            setInterval(updateBlinkingMessage, 2500);
        }

        // Back to top button functionality
        const backToTopBtn = document.getElementById('backToTop');
        
        window.addEventListener('scroll', function() {
            if(window.pageYOffset > 300) {
                backToTopBtn.style.display = 'block';
            } else {
                backToTopBtn.style.display = 'none';
            }
        });
        
        backToTopBtn.addEventListener('click', function() {
            window.scrollTo({
                top: 0,
