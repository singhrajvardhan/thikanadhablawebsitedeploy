            border-collapse: collapse;
            margin-top: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            border-radius: 8px;
            overflow: hidden;
        }

        th, td {
            padding: 16px;
            text-align: left;
            border-bottom: 1px solid var(--sand);
        }

        th {
            background: linear-gradient(to right, var(--maroon), var(--dark-brown));
            color: white;
            font-weight: bold;
            font-size: 18px;
            text-align: center;
