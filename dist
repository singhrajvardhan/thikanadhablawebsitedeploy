<script>
    // Blinking message
    const messages = [
        { text: "राघवाय नमः", color: "#ffd700" },
        { text: "जय माँ आसावरी", color: "#ff6b6b" }
    ];
    let idx = 0;
    const el = document.getElementById('blinking-message');
    el.textContent = messages[0].text;
    el.style.color = messages[0].color;
    el.style.opacity = 1;

    setInterval(() => {
        el.style.opacity = 0;
        setTimeout(() => {
            idx = (idx + 1) % messages.length;
            el.textContent = messages[idx].text;
            el.style.color = messages[idx].color;
            el.style.opacity = 1;
        }, 500);
    }, 2500);

    // Search
    function searchContacts() {
        const filter = document.getElementById('search').value.toUpperCase();
        const rows = document.querySelectorAll('#contactsTable tbody tr');
        let visible = 0;
        rows.forEach(row => {
            const name = row.cells[1]?.textContent.toUpperCase() || '';
            const mobile = row.cells[2]?.textContent.toUpperCase() || '';
            const show = name.includes(filter) || mobile.includes(filter);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    }
</script>
