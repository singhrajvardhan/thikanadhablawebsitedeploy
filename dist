        .contact-count {
            text-align: center;
            margin-bottom: 20px;
            color: var(--maroon);
            font-weight: bold;
            font-size: 18px;
            background-color: rgba(212, 175, 55, 0.1);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid var(--gold);
