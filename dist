        }

        tr:hover {
            background-color: rgba(212, 175, 55, 0.1);
            transform: translateY(-1px);
            transition: all 0.3s;
        }

        td {
            color: var(--dark-brown);
            font-size: 16px;
        }

        td:first-child {
            text-align: center;
            font-weight: bold;
            color: var(--maroon);
            width: 80px;
        }

        /* ==================== FOOTER ==================== */
        #footertop {
            background: linear-gradient(to right, var(--saffron), var(--deep-red), var(--gold));
            height: 6px;
        }

        #footerstrip {
            background-color: var(--dark-brown);
            padding: 35px 20px 25px;
            text-align: center;
            color: var(--cream);
        }

        #footer {
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 25px;
        }

        .footer-links a {
            color: var(--cream);
            text-decoration: none;
            transition: var(--transition);
            font-weight: 500;
        }

        .footer-links a:hover {
            color: var(--gold);
            text-decoration: underline;
        }

        .copyright {
            margin: 20px 0;
            font-size: 0.9rem;
        }

        .copyright a {
            color: var(--gold);
            text-decoration: none;
        }

        .copyright a:hover {
            text-decoration: underline;
        }

        /* Social Icons */
        .parent {
            display: flex;
            justify-content: center;
            gap: 18px;
            margin-top: 25px;
        }

        .child {
            width: 48px;
            height: 48px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 50%;
            transition: var(--transition);
            background-color: var(--cream);
            box-shadow: 0 3px 8px rgba(0,0,0,0.2);
        }

        .child:hover {
            transform: scale(1.15);
            background-color: var(--gold);
        }

        .button {
            border: none;
            background: transparent;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Google Translate */
        #google_translate_element {
            text-align: left;
            margin: 15px 0;
            background: rgba(255,255,255,0.1);
            padding: 8px;
            border-radius: 8px;
        }

        /* ==================== RESPONSIVE ==================== */
        @media (max-width: 768px) {
            #menu {
