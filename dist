        // Hide loader after page load
        window.addEventListener('load', function() {
            setTimeout(function() {
                document.getElementById('loaderContainer').classList.add('hidden');
            }, 500);
        });

        // Blinking message animation
        const messages = [
            { text: "राघवाय नमः", color: "#ffd700" },
            { text: "जय माँ आसावरी", color: "#ff6b6b" },
            { text: "🌹 Badgujar Rajput Heritage 🌹", color: "#ffb347" }
        ];
        let msgIndex = 0;
        const msgEl = document.getElementById('blinking-message');
        
        function updateBlinkingMessage() {
            if(msgEl) {
                msgEl.style.opacity = '0';
                setTimeout(() => {
                    msgIndex = (msgIndex + 1) % messages.length;
                    msgEl.textContent = messages[msgIndex].text;
                    msgEl.style.color = messages[msgIndex].color;
                    msgEl.style.opacity = '1';
                }, 400);
            }
        }
        
        if(msgEl) {
            msgEl.textContent = messages[0].text;
            msgEl.style.color = messages[0].color;
            setInterval(updateBlinkingMessage, 2500);
        }

        // Search function for contacts table
        function searchContacts() {
            let input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("search");
            filter = input.value.toUpperCase();
            table = document.getElementById("contactsTable");
            tr = table.getElementsByTagName("tr");

            for (i = 0; i < tr.length; i++) {
                let nameTd = tr[i].getElementsByTagName("td")[1];
                let mobileTd = tr[i].getElementsByTagName("td")[2];
                
                if (nameTd || mobileTd) {
                    let nameValue = nameTd.textContent || nameTd.innerText;
                    let mobileValue = mobileTd.textContent || mobileTd.innerText;
                    
                    if (nameValue.toUpperCase().indexOf(filter) > -1 || 
                        mobileValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }       
            }
        }
    </script>
